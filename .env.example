# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 逗号分隔的群组 chat_id（负数），留空则不限制
ALLOWED_CHAT_IDS=

# 逗号分隔的用户 user_id，留空则不限制
ALLOWED_USER_IDS=

# ── Claude ────────────────────────────────────────────────────────────────────
# 留空则自动探测（which claude）
CLAUDE_BIN=

# 目录选择时的默认基础路径（仅用于提示，不强制）
DEFAULT_BASE_DIR=/Users/your_username

# ── Proxy ─────────────────────────────────────────────────────────────────────
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897
ALL_PROXY=

# ── Behaviour ─────────────────────────────────────────────────────────────────
# 发送消息后是否显示"处理中"提示
SEND_PROCESSING_HINT=true

# 多少秒没有输出后发第一条提示
PROCESSING_HINT_DELAY=10

# 多少秒没有输出后发第二条提示（建议重启）
LONG_WAIT_HINT_DELAY=60

# 输出缓冲 flush 间隔（秒）
OUTPUT_FLUSH_INTERVAL=1.5

# Telegram 单条消息最大长度
MAX_TELEGRAM_MSG_LEN=3500

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
